# LLM Configuration

# Backend selection: "ollama" or "vllm"
LLM_BACKEND=ollama

# Model to use (Ollama format)
LLM_MODEL=qwen3:8b
# Ollama configuration (for local development)
OLLAMA_BASE_URL=http://localhost:11437/v1

# vLLM configuration (for production)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=vllm

# Whisper transcription backend
# "local" (default): transcribe in-process using the openai-whisper model
#   bundled in this container (CPU or GPU depending on the image/hardware).
# "remote": send audio to an external whisper.cpp-compatible /inference
#   server instead (e.g. a shared GPU host). WHISPER_SERVER_URL must point
#   at that server; the model used is whatever it was started with.
WHISPER_BACKEND=local
WHISPER_SERVER_URL=http://host.docker.internal:8768
WHISPER_REMOTE_TIMEOUT_SECONDS=1800

# Other existing configurations
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHROMA_DB_DIR=chroma_db
COLLECTION_NAME=transcript_embeddings

# API and ingestion guardrails
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
CORS_ALLOW_CREDENTIALS=true
MAX_UPLOAD_FILE_SIZE_MB=500
MAX_UPLOAD_FILES_PER_REQUEST=10
MAX_SEARCH_RESULTS=20
ALLOWED_WHISPER_MODELS=["tiny","base","small","medium","large","turbo"]
ALLOWED_VIDEO_CONTENT_TYPES=["video/mp4","video/avi","video/mov","video/quicktime","video/x-msvideo","video/x-matroska","video/mkv","video/webm"]
# Internet Archive (archive.org) credentials for the video archival CLI
# (scripts/archive_youtube_videos.sh). Required ONLY for real uploads.
# Generate keys at https://archive.org/account/s3.php and paste them below.
# Alternative: `ia configure` writes ~/.config/ia.ini; set IA_CONFIG_FILE to use it.
IA_ACCESS_KEY_ID=
IA_SECRET_ACCESS_KEY=

# Randomized delay (seconds) before each request to archive.org, to avoid
# rate limiting / IP blocking. A random duration in [MIN_DELAY_SECONDS,
# MAX_DELAY_SECONDS] is slept before every archival request.
MIN_DELAY_SECONDS=2
MAX_DELAY_SECONDS=10
